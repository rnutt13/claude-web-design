#!/usr/bin/env bash
set -e

REPO="https://raw.githubusercontent.com/rnutt13/claude-web-design/main"
PROJECT_DIR="$HOME/Claude Web Design"
TEAM_FILE="$PROJECT_DIR/.team"
VERSION_FILE="$PROJECT_DIR/.version"

installed_version() {
  [ -f "$VERSION_FILE" ] && cat "$VERSION_FILE" || echo "unknown"
}

latest_version() {
  curl -fsSL "$REPO/VERSION" 2>/dev/null || echo "unknown"
}

install_cli() {
  if [ -w "/usr/local/bin" ]; then
    curl -fsSL "$REPO/bin/claude-wd" -o "/usr/local/bin/claude-wd"
    chmod +x "/usr/local/bin/claude-wd"
  else
    sudo curl -fsSL "$REPO/bin/claude-wd" -o "/usr/local/bin/claude-wd"
    sudo chmod +x "/usr/local/bin/claude-wd"
  fi
}

download_common() {
  local C="$PROJECT_DIR/assets/logos/common"
  mkdir -p "$C"
  curl -fsSL "$REPO/assets/aws.png" -o "$C/aws.png"
  curl -fsSL "$REPO/assets/Slack.png" -o "$C/Slack.png"
  curl -fsSL "$REPO/assets/mulesoft.png" -o "$C/mulesoft.png"
  curl -fsSL "$REPO/assets/claude.svg" -o "$C/claude.svg"
  curl -fsSL "$REPO/assets/cursor.webp" -o "$C/cursor.webp"
  curl -fsSL "$REPO/assets/ChatGPT.png" -o "$C/ChatGPT.png"
  curl -fsSL "$REPO/assets/GCP%20small.avif" -o "$C/GCP small.avif"
  mkdir -p "$PROJECT_DIR/assets/logos/salesforce"
  curl -fsSL "$REPO/assets/salesforce/Salesforce.png" -o "$PROJECT_DIR/assets/logos/salesforce/Salesforce.png"
}

download_nvidia() {
  mkdir -p "$PROJECT_DIR/assets/logos/nvidia"
  curl -fsSL "$REPO/assets/nvidia/nvidia.png" -o "$PROJECT_DIR/assets/logos/nvidia/nvidia.png"
  download_common
}

