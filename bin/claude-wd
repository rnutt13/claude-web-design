  curl -fsSL "$REPO/assets/disney/imgi_36_Pixar-Logo.jpg" -o "$D/imgi_36_Pixar-Logo.jpg"
  curl -fsSL "$REPO/assets/disney/imgi_37_MARVEL_STUDIOS_LOGO.jpg" -o "$D/imgi_37_MARVEL_STUDIOS_LOGO.jpg"
  curl -fsSL "$REPO/assets/disney/imgi_38_1920-lucasfilm-logo.jpg" -o "$D/imgi_38_1920-lucasfilm-logo.jpg"
